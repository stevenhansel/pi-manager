#!/usr/bin/env bash
# ==============================================================================
# pre-commit hook — run CI lint checks locally before committing
#
# Mirrors the lint job from .github/workflows/ci.yml:
#   - cargo fmt --check
#   - cargo clippy --all-targets --all-features -- -D warnings
# ==============================================================================

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# ── helpers ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
FAILED=0

pass()  { echo -e " ${GREEN}✓${NC} $1"; }
fail()  { echo -e " ${RED}✗${NC} $1"; FAILED=$((FAILED + 1)); }
info()  { echo -e " ${YELLOW}*${NC} $1"; }

# ── 1. cargo fmt --check ─────────────────────────────────────────────────────
echo ""
info "Checking code formatting (cargo fmt --check)..."
if ! cargo fmt --check 2>/dev/null; then
  fail "Formatting issues found — run 'cargo fmt' to fix them"
else
  pass "Formatting looks good"
fi

# ── 2. cargo clippy ──────────────────────────────────────────────────────────
echo ""
info "Linting with clippy (cargo clippy --all-targets --all-features -- -D warnings)..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
  fail "Clippy found issues — review the warnings above"
else
  pass "Clippy is happy"
fi

# ── Summary ──────────────────────────────────────────────────────────────────
echo ""
if [ "$FAILED" -eq 0 ]; then
  echo -e " ${GREEN}✔ All lint checks passed, committing...${NC}"
else
  echo -e " ${RED}✘ $FAILED check(s) failed — fix before committing${NC}"
  echo ""
  echo "  Quick fixes:"
  echo "    cargo fmt              # auto-format code"
  echo "    cargo clippy --fix     # auto-fix clippy suggestions"
  echo ""
fi

exit "$FAILED"
